{
  "manifest_version": 3,
  "name": "Reply by AI for Viator & GetYourGuide",
  "version": "1.3.3",
  "description": "Generate AI-powered replies to Viator and GetYourGuide supplier reviews using Gemini.",
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reply by AI"
  },
  "host_permissions": [
    "https://supplier.viator.com/reviews",
    "https://supplier.getyourguide.com/performance/reviews",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://supplier.viator.com/reviews",
        "https://supplier.getyourguide.com/performance/reviews"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html"
  }
}
